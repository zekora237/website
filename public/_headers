# Cloudflare static-asset headers — Zekora
# https://developers.cloudflare.com/workers/static-assets/headers
# https://opennext.js.org/cloudflare/caching#static-assets-caching

# Site-wide security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Build-hashed assets — immutable, cache forever
/_next/static/*
  Cache-Control: public,max-age=31536000,immutable

# Static images & logos — long cache (path-versioned manually if needed)
/logos/*
  Cache-Control: public,max-age=2592000

/images/*
  Cache-Control: public,max-age=2592000

/og-image.png
  Cache-Control: public,max-age=2592000

/zekora-mark.png
  Cache-Control: public,max-age=2592000

# Icons
/icon.svg
  Cache-Control: public,max-age=86400

/apple-icon.png
  Cache-Control: public,max-age=86400

/favicon.ico
  Cache-Control: public,max-age=86400

# SEO files — short cache so updates propagate fast
/sitemap.xml
  Cache-Control: public,max-age=3600

/robots.txt
  Cache-Control: public,max-age=86400

/manifest.webmanifest
  Cache-Control: public,max-age=86400
